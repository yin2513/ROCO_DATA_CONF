      "right_txt_position": 2,
      "right_txt": "利灯鱼"
    },
    "1006": {
      "id": 1006,
      "group_id": 10001,
      "petbase_id": 3330,
      "appear_time": "2026-01-01 04:00:00",
      "title": "海盔虫",
      "story_page_group": [
        {
          "story_page_type": 1,
          "story_title": "狐主任的小科普",
          "story_txt": "日常潜游，感知到小洛克接近时会进入防御状态，并利用身上的针刺发起攻击。\n常见于海洋。\n精灵研究员观测地点：月牙湖岸；咸水湾；沉船漩涡；商店街周边。"
        },
        {
          "story_page_type": 1,
          "story_title": "疯狂的石头",
          "story_txt": "海盔虫平时喜欢呆在水边或浅水里。当它完全放松、感到安全时，全身的尖刺都会服帖地收拢起来，这时它看起来就像一块深色的、不起眼的石头。在这种状态下，即使有生物从它身边经过，它也往往懒得动弹，安静得仿佛真的是一块石头。但这只是一种安静的假象，一旦受到打扰，它就会立刻展现出防御姿态。"
        },
        {
          "story_page_type": 1,
          "story_title": "小心石头！",
          "story_txt": "刺上会卡着贝壳，木片，海藻。长长的棘刺有大量感光细胞，对光线非常敏感，具有负趋光性，为了逃避光线会在日间抓着各种东西为自己遮挡光线。\n普通的刺盔虫因为棘刺太长，容易被海草缠住，而被磨损了的刺盔虫，它们的短刺既能保护自己，又能减少移动阻力。"
        }
      ],
      "bagitem_id": 320036,
      "animal_rarity_level": 5,
      "txt1": "是棘皮动物门海胆纲动物的统称。\n\n评估等级为濒危（EN） [7]；除此之外，在《世界自然保护联盟（IUCN）濒危物种红色名录》中，欧洲食用海胆被列为近危（NT）物种",
