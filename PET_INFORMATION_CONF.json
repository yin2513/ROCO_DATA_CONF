    "1002": {
      "id": 1002,
      "group_id": 10001,
      "petbase_id": 3490,
      "appear_time": "2026-01-01 04:00:00",
      "title": "吸泥鸥",
      "story_page_group": [
        {
          "story_page_type": 1,
          "story_title": "狐主任的小科普",
          "story_txt": "吸泥鸥日常在岸边吸食淤泥，如有另一只吸泥鸥相随，则可能聚在一起奏乐跳舞。\n常见于河岸，喜好阴雨天。\n精灵研究员观测地点：恶水沼泽；黑水峡。"
        },
        {
          "story_page_type": 1,
          "story_title": "慢吞吞飞行家",
          "story_txt": "吸泥鸥平时出行主要靠走路，情绪那叫一个稳定，天塌下来似乎都不慌。虽然天生有翅膀而且能飞，但极少展示这个本领，以至于很多洛克都以为它不会飞。更让人意外的是，它居然还会游泳！只不过它性子太懒，不爱动弹，宁愿慢悠悠地散步，也不想费力气飞一下或游一会儿。"
        },
        {
          "story_page_type": 1,
          "story_title": "谁都不能阻止我干饭！",
          "story_txt": "进食的时候，总是不慌不忙地把长嘴戳进淤泥里，仔细探索，直到把肚子吃得圆鼓鼓。无论身边发生多热闹的争吵或打斗，它都完全无视，自顾自地找吃的，一副“与世无争”的哲学家模样。"
        }
      ],
      "bagitem_id": 320032,
      "animal_rarity_level": 7,
      "txt1": "蓝脚鲣鸟是鹈形目鲣鸟科鲣鸟属鸟类，又叫结巴鸟。\n蓝脚鲣鸟的长相非常滑稽，乍看之下就像小丑一样，极具特色，是加拉帕戈斯群岛色彩最丰富的鸟类之一。 已成为濒危鸟类，被列为中国国家二级保护动物。",
      "pet_backgroung_image": "Texture2D'/Game/NewRoco/Modules/System/Handbook/Raw/Common/Quiet/Textures/img_BgLawn.img_BgLawn'",
      "egg_image": "PaperSprite'/Game/NewRoco/Modules/System/Activity/Raw/ActivityElvenAmbassador/Frames/img_dantiezhi_006_png.img_dantiezhi_006_png'",
      "left_picture_position": 1,
      "left_picture_image": "Texture2D'/Game/NewRoco/Modules/System/Activity/Raw/ActivityElvenAmbassador/Textures/PetSticker/img_0006.img_0006'",
      "right_picture_position": 1,
      "right_picture_image": "Texture2D'/Game/NewRoco/Modules/System/Activity/Raw/ActivityElvenAmbassador/Textures/PetSticker/img_0012.img_0012'",
      "right_txt_position": 2,
      "right_txt": "泥吼牙"
    },
    "1003": {
      "id": 1003,
      "group_id": 10001,
      "petbase_id": 3237,
      "appear_time": "2026-01-01 04:00:00",
      "title": "小怂猫",
      "story_page_group": [
        {
          "story_page_type": 1,
          "story_title": "狐主任的小科普",
          "story_txt": "小怂猫胆子较小，遇到小洛克时会躲到怒目怂猫身后寻求庇护。\n常见于山林。\n精灵研究员观测地点：咕嘟咕嘟浅滩；港口驻地；拾荒港口；甜水农庄；二叠山丘；望风半岛。"
        },
        {
          "story_page_type": 1,
          "story_title": "吓唬谁呢",
          "story_txt": "小怂猫平时习惯四脚着地走路，但胆子特别小。遇到小洛克时，会猛地用后腿站起来，竭力张开两只前臂，摆出一副“我超凶”的架势，想吓退对方。但这其实就是虚张声势，它自己心里也发虚。这突如其来的举动，常常把只是路过、毫无恶意的洛克搞得一愣，莫名其妙地看着它，场面一度十分尴尬。有时也会躲到怒目怂猫身后寻求庇护。"
        },
        {
          "story_page_type": 1,
          "story_txt": "怒目怂猫胸脯处长着结构独特的气囊，能够迅速膨起至数倍大，形状像是血盆大口，可以吓退敌人。想回到正常姿势需要排出胸脯中的气体，排气的时候会发出非常可爱的声音，一般会在没有其他生物看到的时候偷偷排气。"
        }
      ],
      "bagitem_id": 320033,
      "animal_rarity_level": 4,
      "txt1": "小熊猫（学名：Ailurus fulgens）：是小熊猫科、小熊猫属的一种动物。\n濒危（EN）IUCN标准、《中国国家重点保护野生动物名录》二级",
      "pet_backgroung_image": "Texture2D'/Game/NewRoco/Modules/System/Handbook/Raw/Common/Quiet/Textures/img_MountainForest.img_MountainForest'",
      "egg_image": "PaperSprite'/Game/NewRoco/Modules/System/Activity/Raw/ActivityElvenAmbassador/Frames/img_dantiezhi_002_png.img_dantiezhi_002_png'",
      "left_picture_position": 1,
