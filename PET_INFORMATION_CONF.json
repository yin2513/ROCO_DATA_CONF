    },
    "1005": {
      "id": 1005,
      "group_id": 10001,
      "petbase_id": 3382,
      "appear_time": "2026-01-01 04:00:00",
      "title": "双灯鱼",
      "story_page_group": [
        {
          "story_page_type": 1,
          "story_title": "狐主任的小科普",
          "story_txt": "双灯鱼在游水过程中会偶尔亮灯；\n利灯鱼喜欢搞“伏击”，会悄悄潜游到其他海洋精灵下方将其顶起。\n暂未有相关研究记载。"
        },
        {
          "story_page_type": 1,
          "story_title": "浅水生活家",
          "story_txt": "有谁会知道，头上的灯其实是双灯鱼的鼻孔呢！这决定了它无法长时间潜入深水，不然会憋死，所以只在浅海面活动。\n头上的灯也是情绪指示灯：当它心情愉悦、感到安全时，灯光就会变得明亮；而当它情绪低落、害怕或生气时，灯光则会明显变暗，甚至闪烁不定。"
        },
        {
          "story_page_type": 1,
          "story_title": "笨笨的灯",
          "story_txt": "双灯鱼们用头上灯光的明暗变化来聊天。可惜它们脑子不太灵光，\n有时候游着游着，看到自己倒影里发光的灯，会傻乎乎地以为发现了什么好吃的，猛地一口咬上去……结果当然是被自己“烫”得生疼，灯光瞬间就暗淡了，委屈地沉到水底，半天缓不过来。"
        }
      ],
      "bagitem_id": 320035,
      "animal_rarity_level": 1,
      "txt1": "栖息于500-5000米海底，头部具发光拟饵器官，由第一背鳍特化形成，其腺细胞分泌光素经氧化反应发光，用于诱捕趋光性猎物。",
      "pet_backgroung_image": "Texture2D'/Game/NewRoco/Modules/System/Handbook/Raw/Common/Quiet/Textures/img_BgOcean.img_BgOcean'",
      "egg_image": "PaperSprite'/Game/NewRoco/Modules/System/Activity/Raw/ActivityElvenAmbassador/Frames/img_dantiezhi_001_png.img_dantiezhi_001_png'",
      "left_picture_position": 1,
