{
  "RocoDataRows": {
    "jq01001": {
      "id": "jq01001",
      "msg": "欢迎回家，我的孩子。"
    },
    "jq01002": {
      "id": "jq01002",
      "msg": "而这，便是那个人的样子……"
    },
    "jq01003": {
      "id": "jq01003",
      "msg": "那么，去找到那个人吧！"
    },
    "jq01004": {
      "id": "jq01004",
      "msg": "金色的树影摇曳……"
    },
    "jq01005": {
      "id": "jq01005",
      "msg": "将那个人带来这里……"
    },
    "jq01006": {
      "id": "jq01006",
      "msg": "我们跟上去看看。"
    },
    "jq01007": {
      "id": "jq01007",
      "msg": "还差几只好胚啊。"
    },
    "jq01008": {
      "id": "jq01008",
      "msg": "有人闯进来了！"
    },
    "jq01009": {
      "id": "jq01009",
      "msg": "伊里斯！"
    },
    "jq01010": {
      "id": "jq01010",
      "msg": "哼！"
    },
    "TQ051001": {
      "id": "TQ051001",
      "msg": "堂堂精灵王，如此没用！"
    },
    "TQ051002": {
      "id": "TQ051002",
      "msg": "居然连小小魔法师都打不过！"
    },
    "JQ07CS0401": {
      "id": "JQ07CS0401",
      "msg": "哼！胆敢不听话！"
    },
    "JQ07CS0402": {
      "id": "JQ07CS0402",
      "msg": "看来得认真点料理你们了！"
    },
    "JQ07CS0403": {
      "id": "JQ07CS0403",
      "msg": "大，大人？"
    },
    "JQ07CS0404": {
      "id": "JQ07CS0404",
      "msg": "当你醒来后"
    },
    "JQ07CS0405": {
      "id": "JQ07CS0405",
      "msg": "那时候"
    },
    "JQ07CS0101": {
      "id": "JQ07CS0101",
      "msg": "振作起来，小家伙！"
    },
    "JQ07CS0102": {
      "id": "JQ07CS0102",
      "msg": "你是我认同的朋友！"
    },
    "JQ07CS0201": {
      "id": "JQ07CS0201",
      "msg": "好温暖……"
    },
    "JQ07CS0202": {
      "id": "JQ07CS0202",
      "msg": "切实地传递给了我！"
    },
    "JQ07CS0203": {
      "id": "JQ07CS0203",
      "msg": "一起经历的磨难"
    },
    "JQ07CS0204": {
      "id": "JQ07CS0204",
      "msg": "这些瞬间"
    },
    "JQ07CS0205": {
      "id": "JQ07CS0205",
      "msg": "一双双伸向我背后温暖而有力的手"
    },
    "JQ07CS0206": {
      "id": "JQ07CS0206",
      "msg": "也想要……"
    },
    "JQ07CS0207": {
      "id": "JQ07CS0207",
      "msg": "继承下去！！"
    },
    "JQ07CS0601": {
      "id": "JQ07CS0601",
      "msg": "我们大家的故事！"
    },
    "JQ07CS0602": {
      "id": "JQ07CS0602",
      "msg": "稀客啊，伊里斯"
    },
    "JQ07CS0603": {
      "id": "JQ07CS0603",
      "msg": "大家都是祭祀的食材"
    },
    "JQ07CS0604": {
      "id": "JQ07CS0604",
      "msg": "你该出来了吧"
    },
    "JQ07CS0605": {
      "id": "JQ07CS0605",
      "msg": "破坏契约还敢送上门来？"
    },
    "JQ08CS0501": {
      "id": "JQ08CS0501",
      "msg": "你背叛了我！"
    },
    "JQ08CS0502": {
      "id": "JQ08CS0502",
      "msg": "找到了比你更有价值的合作伙伴"
    },
    "JQ08CS0503": {
      "id": "JQ08CS0503",
      "msg": "你，得付出代价！"
    },
    "JQ08CS0504": {
      "id": "JQ08CS0504",
      "msg": "还是我无法触碰的东西啊"
    },
    "JQ08CS0601": {
      "id": "JQ08CS0601",
      "msg": "毕竟「魇力」"
    },
    "JQ08CS0602": {
      "id": "JQ08CS0602",
      "msg": "那么，把你的星盘拿出来吧"
    },
    "JQ08CS0603": {
      "id": "JQ08CS0603",
      "msg": "哼哼……"
    },
    "JQ08CS0604": {
      "id": "JQ08CS0604",
      "msg": "接下来，看我表演！"
    },
    "JQ08CS0605": {
      "id": "JQ08CS0605",
      "msg": "迪莫！迪莫！"
    },
    "JQ08CS0606": {
      "id": "JQ08CS0606",
      "msg": "迪莫，迪莫，迪莫！"
    },
    "JQ08CS0607": {
      "id": "JQ08CS0607",
      "msg": "我的伙伴！"
    },
    "JQ08CS0608": {
      "id": "JQ08CS0608",
      "msg": "说来话长"
    },
    "JQ08CS0609": {
      "id": "JQ08CS0609",
      "msg": "不好！难道它要……"
    },
    "JQ08CS0610": {
      "id": "JQ08CS0610",
      "msg": "嗯？"
    },
    "JQ08CS0611": {
      "id": "JQ08CS0611",
      "msg": "孩子，你到底在干什么？"
    },
    "JQ08CS0612": {
      "id": "JQ08CS0612",
      "msg": "嗯？"
    },
    "JQ08CS0613": {
      "id": "JQ08CS0613",
      "msg": "可是……"
    },
    "JQ08CS0614": {
      "id": "JQ08CS0614",
      "msg": "孩子……！雪莉，她绝不希望你走上这条路……"
    },
    "JQ08CS0615": {
      "id": "JQ08CS0615",
      "msg": "不……"
    },
    "JQ08CS0616": {
      "id": "JQ08CS0616",
      "msg": "但我必须这么做。"
    },
    "JQ08CS0617": {
      "id": "JQ08CS0617",
      "msg": "封印被破坏了！"
    },
    "JQ08CS0618": {
      "id": "JQ08CS0618",
      "msg": "你们怎么……"
    },
    "JQ08CS0619": {
      "id": "JQ08CS0619",
      "msg": ""
    },
