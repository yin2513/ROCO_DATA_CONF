{
  "RocoDataRows": {
    "200001": {
      "id": "200001",
      "track_id": "20",
      "begin_time": "00:00:01,200",
      "end_time": "00:00:06,466",
      "content": "“裘卡，控制你自己！好好想想，你究竟想成为怎样的精灵！”"
    },
    "200002": {
      "id": "200002",
      "track_id": "20",
      "begin_time": "00:00:06,733",
      "end_time": "00:00:12,300",
      "content": "请原谅我！我只是……只是想和你们在一起玩……你们会明白的……"
    },
    "200003": {
      "id": "200003",
      "track_id": "20",
      "begin_time": "00:00:13,000",
      "end_time": "00:00:15,866",
      "content": "与其追求虚妄的平衡，还不如放弃这一切，随性而行！"
    },
    "200004": {
      "id": "200004",
      "track_id": "20",
      "begin_time": "00:00:16,133",
      "end_time": "00:00:17,800",
      "content": "但冥古龙的噩梦精灵大军，如潮水一般……无穷无尽"
    },
    "200005": {
      "id": "200005",
      "track_id": "20",
      "begin_time": "00:00:20,533",
      "end_time": "00:00:26,500",
      "content": "光芒闪耀间"
    },
    "210001": {
      "id": "210001",
      "track_id": "21",
      "begin_time": "00:00:01,566",
      "end_time": "00:00:06,566",
      "content": "亦将开创璀璨的明天"
    },
    "210002": {
      "id": "210002",
      "track_id": "21",
      "begin_time": "00:00:07,566",
      "end_time": "00:00:13,333",
      "content": "珂赛特"
    },
    "210003": {
      "id": "210003",
      "track_id": "21",
      "begin_time": "00:00:13,566",
      "end_time": "00:00:22,966",
      "content": "200年前的那一天"
    },
    "210004": {
      "id": "210004",
      "track_id": "21",
      "begin_time": "00:00:23,566",
      "end_time": "00:00:30,966",
      "content": "纵然"
    },
    "210005": {
      "id": "210005",
      "track_id": "21",
      "begin_time": "00:00:31,033",
      "end_time": "00:00:37,066",
      "content": "不仅是小格里芬举起了星盘"
    },
    "220001": {
      "id": "220001",
      "track_id": "22",
      "begin_time": "00:00:01,233",
      "end_time": "00:00:10,700",
      "content": "就是"
    },
    "220002": {
      "id": "220002",
      "track_id": "22",
      "begin_time": "00:00:10,200",
      "end_time": "00:00:18,666",
      "content": "但我能感受到"
    },
    "220003": {
      "id": "220003",
      "track_id": "22",
      "begin_time": "00:00:18,466",
      "end_time": "00:00:27,000",
      "content": "请举起你们的双手"
    },
    "220004": {
      "id": "220004",
      "track_id": "22",
      "begin_time": "00:00:27,533",
      "end_time": "00:00:34,566",
      "content": "守护彼此的心愿"
    },
    "230001": {
      "id": "230001",
      "track_id": "23",
      "begin_time": "00:00:00,500",
      "end_time": "00:00:04,500",
      "content": "唤醒精灵王之魂！"
    },
    "230002": {
      "id": "230002",
      "track_id": "23",
      "begin_time": "00:00:05,167",
      "end_time": "00:00:06,733",
      "content": "200年前我们曾以愿力之辉封印冥古龙"
    },
    "230003": {
      "id": "230003",
      "track_id": "23",
      "begin_time": "00:00:08,200",
      "end_time": "00:00:13,467",
      "content": "此刻"
    },
    "230004": {
      "id": "230004",
      "track_id": "23",
      "begin_time": "00:00:14,500",
      "end_time": "00:00:17,900",
      "content": "信念"
    },
    "230005": {
      "id": "230005",
      "track_id": "23",
      "begin_time": "00:00:19,333",
      "end_time": "00:00:22,567",
      "content": "我"
    },
    "230006": {
      "id": "230006",
      "track_id": "23",
      "begin_time": "00:00:23,700",
      "end_time": "00:00:27,333",
      "content": "它们说，总觉得背后有一双眼睛"
    },
    "230007": {
      "id": "230007",
      "track_id": "23",
      "begin_time": "00:00:28,467",
      "end_time": "00:00:30,033",
      "content": "就像……在挑选猎物"
    },
